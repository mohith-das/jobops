# mcp-jsa configuration

# Network
MCP_JSA_PORT=7891
MCP_JSA_HOST=127.0.0.1

# Auth — bearer token gating /mcp, /files/*, and the dashboard (all carry PII).
# Leave empty for localhost-only use (frictionless). REQUIRED to bind non-localhost:
# with MCP_JSA_HOST != 127.0.0.1 and no token, the server refuses to start (default-deny).
# Generate one with:  openssl rand -hex 32
MCP_JSA_AUTH_TOKEN=

# Project root — where cv.md, config/profile.yml, portals.yml live.
# Defaults to the directory this server runs from.
# To reuse the existing career-ops/ data, point it there:
# MCP_JSA_PROJECT_ROOT=/Users/you/Documents/Career Ops/career-ops
MCP_JSA_PROJECT_ROOT=

# Data + outputs (resolved relative to the server install dir, not project root)
MCP_JSA_DATA_DIR=./data
MCP_JSA_OUTPUT_DIR=./output

# Scoring — api/batch paths prefer MCP sampling (your connected client's model; no key).
# Set false to force the BYO-key provider below even when the client supports sampling.
MCP_JSA_SAMPLING=true

# LLM provider — BYO-key FALLBACK for api/batch paths when the client can't sample.
# chat-mode (default) runs zero LLM calls server-side; the chat client is the brain.
MCP_JSA_LLM_PROVIDER=gemini     # gemini | deepseek | none
MCP_JSA_LLM_MODEL=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Scheduler — off by default. Enable specific jobs via scheduler_enable MCP tool.
MCP_JSA_SCHEDULER_ENABLED=false

# Visa scoring — set to `false` if you don't need visa/H1B signal (US citizens, non-US
# users, etc.). When false, visa_fit is dropped from the rubric, weights renormalize to
# resume 0.6 / taste 0.4, the visa_signal / import_h1b / import_linkedin tools are hidden,
# and visa columns are stripped from tool responses. Default: true.
MCP_JSA_VISA_SCORING=true

# Public URL emitted in artifact links (resume / cover / report / tracker / etc.).
# Default: http://<host>:<port> — works when client + server are on the same machine.
# Set this when the server runs on a remote host (Tailscale / LAN / cloud) so links are
# reachable from your chat machine. Examples:
#   MCP_JSA_PUBLIC_BASE_URL=http://100.64.0.5:7891      # Tailscale 100.x
#   MCP_JSA_PUBLIC_BASE_URL=https://jobs.example.ts.net # Tailscale magic DNS
#   MCP_JSA_PUBLIC_BASE_URL=https://jobs.example.com    # reverse proxy
# Malformed values warn but do not crash the server (falls back to default).
MCP_JSA_PUBLIC_BASE_URL=

# Templates (resume + cover letter themes).
# Bundled themes live under the package's templates/themes/<name>/. You can author
# your own themes in any directory and point MCP_JSA_TEMPLATE_DIR at it — the
# loader checks your dir FIRST, so dropping a `default/` folder in there
# overrides the bundled default. List available themes with:
#   npx job_ops-mcp templates
# Each theme contains resume.tex, cover.tex, resume.html, cover.html (any subset).
# See TEMPLATES.md for the placeholder contract a custom theme must satisfy.
MCP_JSA_TEMPLATE_DIR=
# Theme used when render_pdf is called without an explicit `template` argument.
MCP_JSA_DEFAULT_TEMPLATE=default

# Playwright — usually no config needed once `npm run playwright:install` is done.
